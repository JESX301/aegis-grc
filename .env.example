# Copy to .env and adjust. All values are optional (sane local defaults apply).

# Long random string used to sign session cookies. REQUIRED in production.
AEGIS_SECRET_KEY=change-me-to-a-long-random-string

# --- Production / VM deploy (docker-compose.prod.yml + Caddy) ---
# Your domain; Caddy auto-provisions HTTPS for it. Point an A record at the VM first.
DOMAIN=app.example.com
# In production, set demo seeding off (and use a real AEGIS_SECRET_KEY above):
# AEGIS_SEED_DEMO=false
# Optional image tag override:
# APP_IMAGE=aegis-grc:latest

# Database. Default is local SQLite under AEGIS_DATA_DIR.
# PostgreSQL example (cloud):
# DATABASE_URL=postgresql+psycopg://aegis:aegis@db:5432/aegis

# Where the SQLite file + data live.
AEGIS_DATA_DIR=./data

# Seed demo users / example assessment on first run.
AEGIS_SEED_DEMO=true
AEGIS_DEMO_PASSWORD=aegis123

# Maintenance/superuser account — ALWAYS created so a real deploy can sign in.
# Set a strong password here. If left blank in a non-demo deploy (AEGIS_SEED_DEMO=false),
# a strong random password is generated and printed to the server logs on first boot;
# sign in and change it via My Account.
AEGIS_ADMIN_USERNAME=admin
# AEGIS_ADMIN_PASSWORD=set-a-strong-password

# App display name.
AEGIS_APP_NAME=Aegis GRC

# Optional: only needed if you wire up the (future) AI assist layer.
# ANTHROPIC_API_KEY=sk-ant-...
