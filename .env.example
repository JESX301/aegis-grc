# Copy to .env and adjust. All values are optional (sane local defaults apply).

# Long random string used to sign session cookies. REQUIRED in production.
AEGIS_SECRET_KEY=change-me-to-a-long-random-string

# Database. Default is local SQLite under AEGIS_DATA_DIR.
# PostgreSQL example (cloud):
# DATABASE_URL=postgresql+psycopg://aegis:aegis@db:5432/aegis

# Where the SQLite file + data live.
AEGIS_DATA_DIR=./data

# Seed demo users / example assessment on first run.
AEGIS_SEED_DEMO=true
AEGIS_DEMO_PASSWORD=aegis123

# App display name.
AEGIS_APP_NAME=Aegis GRC

# Optional: only needed if you wire up the (future) AI assist layer.
# ANTHROPIC_API_KEY=sk-ant-...
