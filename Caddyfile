# Caddy v2 — automatic HTTPS reverse proxy (used by docker-compose.prod.yml).
# Caddy provisions and auto-renews a Let's Encrypt cert for $DOMAIN, terminates
# TLS, and proxies to the app container over the internal compose network.
# Set DOMAIN in .env. For local testing, set DOMAIN=localhost (Caddy issues a local cert).

{$DOMAIN} {
	reverse_proxy app:8000

	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
